# govcheck 環境變數範例 — 複製為 .env 後依需求調整（.env 已 gitignore，勿入庫）。
# 所有變數皆有硬碼/YAML 預設值，可留空或整段不設；機密（api_key/token）僅能由環境變數提供，
# 禁止寫入 src/govcheck/config/*.yaml。
# 詳細語意見 src/govcheck/logging_setup.py / llm/config.py / rag/config.py。

# ── Logging（技術維運 + 治理稽核） ──────────────────────────────────────────
# profile 細節程度總開關：dev=全流程(DEBUG，含 llm_raw 除錯落檔) / prod=重點(INFO) / quiet=只剩錯誤(WARNING)
# 上線環境勿設為 dev（會落地保存 LLM request/response 全文於 logs/llm_raw/）。
GOVCHECK_LOG_PROFILE=prod
# 細粒度覆寫（留空 → 由 profile 推導）：DEBUG / INFO / WARNING / ERROR / CRITICAL
GOVCHECK_LOG_LEVEL=
# log 檔輸出目錄（留空 → repo root/logs）
GOVCHECK_LOG_DIR=
# 是否同時輸出到 console(stderr)
GOVCHECK_LOG_CONSOLE=true
# 單一 log 檔輪替門檻（bytes）與保留份數
GOVCHECK_LOG_MAX_BYTES=5000000
GOVCHECK_LOG_BACKUP_COUNT=5
# 稽核記錄「誰」（目前無登入機制，best-effort 手動填）
GOVCHECK_OPERATOR=

# ── LLM 判讀端點（F03 佐證比較；OpenAI 相容 chat/completions） ──────────────
# 預設關閉；設 1 才會呼叫 LLM（否則僅跑規則式檢查）
GOVCHECK_LLM_ENABLED=false
# 本機開發預設走 ollama；內部/正式端點請覆寫為行內部署位址
GOVCHECK_LLM_BASE_URL=http://localhost:11434/v1
# 本機 ollama 範例模型；請依實際部署覆寫
GOVCHECK_LLM_MODEL=gemma3:4b
# 機密：僅走環境變數，禁止寫入 yaml。本機 ollama 通常免填。
GOVCHECK_LLM_API_KEY=
# 單次請求逾時（秒）
GOVCHECK_LLM_TIMEOUT=60
# 判讀求穩定，預設 0
GOVCHECK_LLM_TEMPERATURE=0
# 單次審查送 LLM 的檢核項上限（安全閥）
GOVCHECK_LLM_MAX_ITEMS=30
# 單次 LLM 呼叫送審的檢核項數（批次以減少呼叫）
GOVCHECK_LLM_BATCH_SIZE=8

# ── RAG 法規檢索輔助判讀（Phase 3；一體啟停：GOVCHECK_LLM_ENABLED AND rag.enabled） ──
# 預設關閉
GOVCHECK_RAG_ENABLED=false
# build-time 產物路徑（gitignored；runtime 只讀查表）
GOVCHECK_RAG_MAPPING_PATH=data/rag/retrieval_map.json
# RAG 判讀批次大小（canonical 摘錄使 prompt 較長，保守起步）
GOVCHECK_RAG_BATCH_SIZE=2
# 每檢核項最多引用條文段數
GOVCHECK_RAG_MAX_SECTIONS_PER_ITEM=3
# 每段摘錄字數上限（prompt 預算防護）
GOVCHECK_RAG_MAX_EXCERPT_CHARS=300
# RAG 判讀獨立逾時（秒）；不沿用 LLM chat 的 60s
GOVCHECK_RAG_TIMEOUT=120
# 單次送 RAG 判讀的檢核項上限（安全閥）
GOVCHECK_RAG_MAX_ITEMS=30
# 檢索分數門檻（留空 → None，不過濾）
GOVCHECK_RAG_SCORE_THRESHOLD=0.08

# ── RAG build-time / embedding（僅建索引 scripts/build_regulation_index.py 需要） ──
# embedding 端點（OpenAI 相容 /embeddings；本機開發預設 ollama）
GOVCHECK_RAG_EMBEDDING_BASE_URL=http://localhost:11434/v1
GOVCHECK_RAG_EMBEDDING_MODEL=bge-m3
GOVCHECK_RAG_EMBEDDING_DIM=1024
# 機密：僅走環境變數，禁止寫入 yaml。本機 ollama 通常免填。
GOVCHECK_RAG_EMBEDDING_API_KEY=
# Milvus Lite（預設，本機檔案）；遷移至 Milvus Server 時改為 http://<server-host>:19530
GOVCHECK_RAG_MILVUS_URI=data/milvus/governance.db
# 機密：僅 Milvus Server 啟用認證時需要（Lite 模式免填）
GOVCHECK_RAG_MILVUS_TOKEN=
# 檢索回傳條文段數
GOVCHECK_RAG_TOP_K=4
